# Copy this file to .env. Never commit the real .env file.
# Leave ENABLE_GROQ_ENRICHMENT=false until you are ready to use the API.
GROQ_API_KEY=
GROQ_MODEL=
ENABLE_GROQ_ENRICHMENT=false
# Enables the evidence-only Incident Commander. It never changes the risk score.
ENABLE_GROQ_INCIDENT_COMMANDER=false
# Optional: enables official New York road and bridge events for New York locations.
# Register for a developer key at 511ny.org; leave empty for weather and flood alerts only.
NY511_API_KEY=
# Required for Docker's PostgreSQL/PostGIS audit database. Use a strong secret outside local development.
POSTGRES_PASSWORD=change-me-before-production
